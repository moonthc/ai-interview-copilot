generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  name         String?
  email        String    @unique
  passwordHash String
  createdAt    DateTime  @default(now())
  resumes      Resume[]
  jobPositions JobPosition[]
  sessions     InterviewSession[]
  answers      Answer[]

  @@map("users")
}

model Resume {
  id            String    @id @default(cuid())
  userId        String
  filePath      String
  parsedContent Json?
  createdAt     DateTime  @default(now())
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions      InterviewSession[]

  @@index([userId])
  @@map("resumes")
}

model JobPosition {
  id          String    @id @default(cuid())
  userId      String
  title       String
  description String?
  parsedJd    Json?
  matchResult Json?
  questionBank Json?
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions    InterviewSession[]

  @@index([userId])
  @@map("job_positions")
}

model InterviewSession {
  id             String    @id @default(cuid())
  userId         String
  resumeId       String?
  jobPositionId  String?
  status         String    @default("pending")
  mode           String    @default("standard")
  reportJson     Json?
  createdAt      DateTime  @default(now())
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  resume         Resume?   @relation(fields: [resumeId], references: [id])
  jobPosition    JobPosition? @relation(fields: [jobPositionId], references: [id])
  questions      Question[]

  @@index([userId])
  @@index([resumeId])
  @@index([jobPositionId])
  @@map("interview_sessions")
}

model Question {
  id               String   @id @default(cuid())
  sessionId        String
  category         String?
  content          String
  order            Int
  session          InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  answers          Answer[]
  dialogueMessages DialogueMessage[]

  @@index([sessionId])
  @@map("questions")
}

model Answer {
  id              String   @id @default(cuid())
  questionId      String
  userId          String
  userAnswer      String   @db.Text
  score           Int?
  feedbackJson    Json?
  followUpQuestion String? @db.Text
  createdAt       DateTime @default(now())
  question        Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([questionId])
  @@index([userId])
  @@map("answers")
}

model DialogueMessage {
  id         String   @id @default(cuid())
  questionId String
  role       String
  content    String   @db.Text
  round      Int
  createdAt  DateTime @default(now())
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
  @@map("dialogue_messages")
}